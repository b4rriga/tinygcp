#include "tinygcp.h"

void tinyGCP_init(void)
{
	line_char_count = 0;
	line_buf[line_char_count] = '\0';
	comments = line_buf;
	last_comment = comments;
	block_delete = false;
	begin_end = false;
	line_ready = false;
}

bool tinyGCP_append_char(char c)
{
	if (line_ready) tinyGCP_init();

	if (c == '\r' || c == '\n') {
		// Ignore CR so as to support CRLF and NL format
		if (c == '\n') line_ready = true;
	} else {
		line_buf[line_char_count] = c;
		line_char_count++;

		// TODO: throw error?
		if (line_char_count > MAX_LINE_SIZE)
			tinyGCP_init();

		line_buf[line_char_count] = '\0';
	}

	return line_ready;
}

